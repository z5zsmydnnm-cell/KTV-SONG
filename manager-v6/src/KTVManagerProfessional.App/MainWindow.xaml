<Window x:Class="KTVManagerProfessional.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="KTV Manager Professional Build 001"
        Height="720"
        MinHeight="560"
        Width="1120"
        MinWidth="920"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Grid Background="#F6F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#D8DEE9" BorderThickness="0,0,0,1" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="音圓 PDF 匯入" FontSize="22" FontWeight="SemiBold" Foreground="#20242A" />
                    <TextBlock x:Name="StatusText"
                               Margin="0,6,0,0"
                               Foreground="#5B6573"
                               Text="可從 Windows 檔案總管拖曳 PDF 到此視窗，或按右側按鈕選擇 PDF。" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="132"
                        Height="38"
                        Margin="16,0,8,0"
                        Click="ChoosePdf_Click"
                        Content="選擇 PDF" />
                <Button Grid.Column="2"
                        Width="132"
                        Height="38"
                        Click="ExportCsv_Click"
                        Content="匯出 master.csv" />
            </Grid>
        </Border>

        <DataGrid x:Name="SongsGrid"
                  Grid.Row="1"
                  Margin="18"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="歌號" Binding="{Binding SongNumber}" Width="110" />
                <DataGridTextColumn Header="歌名" Binding="{Binding Title}" Width="2*" />
                <DataGridTextColumn Header="歌手" Binding="{Binding Artist}" Width="2*" />
                <DataGridTextColumn Header="語言" Binding="{Binding Language}" Width="90" />
                <DataGridTextColumn Header="音圓代號" Binding="{Binding BrandCode}" Width="110" />
                <DataGridTextColumn Header="集數" Binding="{Binding Volume}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Margin="18,0,18,18" Background="White" BorderBrush="#D8DEE9" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Padding="12,10"
                           FontWeight="SemiBold"
                           Text="解析失敗行" />
                <ListBox x:Name="IssuesList"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock TextWrapping="Wrap">
                                <Run Text="Line " />
                                <Run Text="{Binding LineNumber}" />
                                <Run Text=": " />
                                <Run Text="{Binding Line}" />
                                <Run Text=" - " />
                                <Run Text="{Binding Reason}" />
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   Padding="18,0,18,14"
                   Foreground="#687386"
                   Text="{Binding ElementName=GitStatusText, Path=Text}" />
        <TextBlock x:Name="GitStatusText"
                   Visibility="Collapsed" />
    </Grid>
</Window>
